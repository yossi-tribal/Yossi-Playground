<?xml version="1.0" encoding="UTF-8"?>
<CustomObject xmlns="http://soap.sforce.com/2006/04/metadata">
            <deploymentStatus>Deployed</deploymentStatus>
            <description>Junction object that stores individual responses from sales representatives to qualification questions for each lead. Tracks Yes/No responses with timestamps for audit trail and supports partial completion of the qualification process.</description>
            <enableActivities>true</enableActivities>
            <enableBulkApi>true</enableBulkApi>
            <enableFeeds>true</enableFeeds>
            <enableHistory>true</enableHistory>
            <enableReports>true</enableReports>
            <enableSearch>true</enableSearch>
            <enableSharing>true</enableSharing>
            <enableStreamingApi>true</enableStreamingApi>
            <externalSharingModel>Private</externalSharingModel>
            <label>Lead Question Response</label>
            <nameField>
                <displayFormat>LQR-{00000}</displayFormat>
                <label>Response Number</label>
                <type>AutoNumber</type>
            </nameField>
            <pluralLabel>Lead Question Responses</pluralLabel>
            <searchLayouts>
                <searchFilterFields>NAME</searchFilterFields>
                <searchResultsAdditionalFields>CREATED_DATE</searchResultsAdditionalFields>
            </searchLayouts>
            <sharingModel>ReadWrite</sharingModel>
            <visibility>Public</visibility>
        </CustomObject>