<?xml version="1.0" encoding="UTF-8"?>
<PermissionSet xmlns="http://soap.sforce.com/2006/04/metadata">
            <fullName>OHT_Opportunity_Health_Full_Access</fullName>
            <label>Opportunity Health Full Access</label>
            <description>Grants full access to Opportunity Health Thermostat custom fields, Apex classes (controller and batch), and LWC component. Includes read access to Opportunity, Task, and OpportunityHistory objects.</description><!-- Field Permissions - Make custom fields visible and editable based on isEditable (required fields are excluded) -->
            
            <fieldPermissions>
                
                <editable>true</editable>
                
                <field>Opportunity.OHT_Health_Score__c</field>
                <readable>true</readable>
            </fieldPermissions>
            
            <fieldPermissions>
                
                <editable>true</editable>
                
                <field>Opportunity.OHT_Risk_Level__c</field>
                <readable>true</readable>
            </fieldPermissions>
            
            <fieldPermissions>
                
                <editable>true</editable>
                
                <field>Opportunity.OHT_Health_Score_Last_Updated__c</field>
                <readable>true</readable>
            </fieldPermissions>
            <!-- Apex Class Access - Grant access to Apex classes -->
            
            <classAccesses>
                <apexClass>OHT_OpportunityHealthController</apexClass>
                <enabled>true</enabled>
            </classAccesses>
            
            <classAccesses>
                <apexClass>OHT_OpportunityHealthBatch</apexClass>
                <enabled>true</enabled>
            </classAccesses>
            
            
            <!-- Run Flow Permission - Required when project has screen flows -->
            
            
            <hasActivationRequired>false</hasActivationRequired>
        </PermissionSet>