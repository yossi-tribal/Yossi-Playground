<?xml version="1.0" encoding="UTF-8"?>
<PermissionSet xmlns="http://soap.sforce.com/2006/04/metadata">
            <fullName>CSD_CS_Dashboard_Full_Access</fullName>
            <label>CS Dashboard Full Access</label>
            <description>Full access to Customer Success Dashboard fields and components with streamlined 2-field data model</description><!-- Field Permissions - Make custom fields visible and editable based on isEditable (required fields are excluded) -->
            
            <fieldPermissions>
                
                <editable>true</editable>
                
                <field>Account.CSD_Account_Health_Score__c</field>
                <readable>true</readable>
            </fieldPermissions>

            <fieldPermissions>

                <editable>false</editable>

                <field>Account.CSD_Previous_Health_Score__c</field>
                <readable>true</readable>
            </fieldPermissions>

            <fieldPermissions>
                
                <editable>true</editable>
                
                <field>Account.CSD_Primary_CSM__c</field>
                <readable>true</readable>
            </fieldPermissions>
            <!-- Apex Class Access - Grant access to Apex classes -->

            <classAccesses>
                <apexClass>CSD_AccountHealthScoreHandler</apexClass>
                <enabled>true</enabled>
            </classAccesses>

            <classAccesses>
                <apexClass>CSD_CSDashboardController</apexClass>
                <enabled>true</enabled>
            </classAccesses>

            <classAccesses>
                <apexClass>CSD_CaseHealthScoreHandler</apexClass>
                <enabled>true</enabled>
            </classAccesses>

            <classAccesses>
                <apexClass>CSD_TaskHealthScoreHandler</apexClass>
                <enabled>true</enabled>
            </classAccesses>

            <classAccesses>
                <apexClass>CSD_EventHealthScoreHandler</apexClass>
                <enabled>true</enabled>
            </classAccesses>

            <classAccesses>
                <apexClass>CSD_CSMPortfolioController</apexClass>
                <enabled>true</enabled>
            </classAccesses>

            <!-- Application Visibility - Grant access to Customer Success Management app -->
            <applicationVisibilities>
                <application>Customer_Success_Management</application>
                <visible>true</visible>
            </applicationVisibilities>

            <!-- Custom Tab Visibility - Grant access to CSM Portfolio Dashboard tab -->
            <tabSettings>
                <tab>CSM_Portfolio_Dashboard</tab>
                <visibility>Visible</visibility>
            </tabSettings>

            <!-- Standard Object Permissions - Grant read access to objects queried by the dashboard -->
            <objectPermissions>
                <allowCreate>false</allowCreate>
                <allowDelete>false</allowDelete>
                <allowEdit>false</allowEdit>
                <allowRead>true</allowRead>
                <object>Account</object>
                <viewAllRecords>false</viewAllRecords>
                <modifyAllRecords>false</modifyAllRecords>
            </objectPermissions>

            <objectPermissions>
                <allowCreate>false</allowCreate>
                <allowDelete>false</allowDelete>
                <allowEdit>false</allowEdit>
                <allowRead>true</allowRead>
                <object>Case</object>
                <viewAllRecords>false</viewAllRecords>
                <modifyAllRecords>false</modifyAllRecords>
            </objectPermissions>

            <objectPermissions>
                <allowCreate>false</allowCreate>
                <allowDelete>false</allowDelete>
                <allowEdit>false</allowEdit>
                <allowRead>true</allowRead>
                <object>Task</object>
                <viewAllRecords>false</viewAllRecords>
                <modifyAllRecords>false</modifyAllRecords>
            </objectPermissions>

            <objectPermissions>
                <allowCreate>false</allowCreate>
                <allowDelete>false</allowDelete>
                <allowEdit>false</allowEdit>
                <allowRead>true</allowRead>
                <object>Event</object>
                <viewAllRecords>false</viewAllRecords>
                <modifyAllRecords>false</modifyAllRecords>
            </objectPermissions>

            <objectPermissions>
                <allowCreate>false</allowCreate>
                <allowDelete>false</allowDelete>
                <allowEdit>false</allowEdit>
                <allowRead>true</allowRead>
                <object>Opportunity</object>
                <viewAllRecords>false</viewAllRecords>
                <modifyAllRecords>false</modifyAllRecords>
            </objectPermissions>

            <objectPermissions>
                <allowCreate>false</allowCreate>
                <allowDelete>false</allowDelete>
                <allowEdit>false</allowEdit>
                <allowRead>true</allowRead>
                <object>Contact</object>
                <viewAllRecords>false</viewAllRecords>
                <modifyAllRecords>false</modifyAllRecords>
            </objectPermissions>

            <!-- Run Flow Permission - Required when project has screen flows -->


            <hasActivationRequired>false</hasActivationRequired>
        </PermissionSet>